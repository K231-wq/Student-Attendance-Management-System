<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Student_Attendance_Management_System"
             xmlns:helpers="clr-namespace:Student_Attendance_Management_System.Helpers"
             x:Class="Student_Attendance_Management_System.App">
    <Application.Resources>
        <ResourceDictionary>
            <helpers:ThresholdConverter x:Key="ThresholdConverter" />
            <helpers:GreaterThanConverter x:Key="GreaterThanConverter" />
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
