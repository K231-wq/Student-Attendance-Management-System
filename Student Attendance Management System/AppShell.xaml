<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Student_Attendance_Management_System.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:login="clr-namespace:Student_Attendance_Management_System.View.login"
    FlyoutBehavior="Disabled"
    FlyoutBackgroundColor="Blue"
    >

    <ShellContent
        ContentTemplate="{DataTemplate login:LoginPage}" 
        Route="Login"
        />
    <ShellContent
        ContentTemplate="{DataTemplate login:RegisterPage}" 
        Route="Register"
        />
</Shell>
