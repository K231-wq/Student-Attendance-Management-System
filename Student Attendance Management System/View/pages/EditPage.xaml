<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Student_Attendance_Management_System.View.pages.EditPage"
             xmlns:model="clr-namespace:Student_Attendance_Management_System.Model"
             xmlns:viewModel="clr-namespace:Student_Attendance_Management_System.ViewModel"
             x:DataType="viewModel:EditViewModel"
             Title="EditPage">
    <ScrollView BackgroundColor="#547792">
        <VerticalStackLayout Padding="20" Spacing="15">

            <VerticalStackLayout 
                HorizontalOptions="Center" 
                Spacing="10" 
                Margin="0,0,0,20">
                <Frame 
                    HeightRequest="120" 
                    WidthRequest="120" 
                    CornerRadius="60" 
                    Padding="0" 
                    IsClippedToBounds="True">
                    <Image 
                        Source="{Binding ProfileImagePreview}" 
                        Aspect="AspectFill"
                        />
                </Frame>
                <Button 
                    Text="Change Photo" 
                    FontSize="12" 
                    Style="{StaticResource ButtonOutline}" 
                    HeightRequest="35"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    FontAttributes="Bold"
                    Command="{Binding PickPhotoCommand}"
                    
                    />
            </VerticalStackLayout>

            <StackLayout Orientation="Horizontal" Spacing="10" VerticalOptions="Center" HorizontalOptions="Center">
                <Label Text="uid: " TextColor="White" FontSize="12" FontAttributes="Bold" VerticalTextAlignment="Center"/>
                <Label Text="{Binding Student.uid}" TextColor="White" FontAttributes="Bold" FontSize="14" IsEnabled="False"/>
            </StackLayout>


            <Label Text="Full Name" FontAttributes="Bold" TextColor="White"/>
            <Entry 
                Text="{Binding Student.name}" 
                Placeholder="Enter Name" 
                Style="{StaticResource EntryStyle}"
                BackgroundColor="Black"
                />


            <Label Text="Email Address" FontAttributes="Bold" TextColor="White" VerticalTextAlignment="Center"/>
            <Entry 
                Text="{Binding Student.email}" 
                Keyboard="Email" 
                Placeholder="Enter Email" 
                Style="{StaticResource EntryStyle}"
                BackgroundColor="Black"
                />

            <FlexLayout
                JustifyContent="SpaceEvenly"
                AlignItems="Center"
                HorizontalOptions="Fill"
                >
                <StackLayout Orientation="Horizontal" Spacing="10" VerticalOptions="Center">
                    <Label Text="Major: " TextColor="White" FontSize="12" FontAttributes="Bold" VerticalTextAlignment="Center"/>
                    <Label Text="{Binding Student.major.name}" TextColor="White" FontSize="18" VerticalTextAlignment="Center" FontAttributes="Bold"/>
                </StackLayout>
                <StackLayout Orientation="Horizontal" Spacing="10" VerticalOptions="Center">
                    <Label Text="Change Major: " FontSize="12" FontAttributes="Bold" TextColor="White" VerticalTextAlignment="Center"/>
                    <Picker ItemsSource="{Binding Majors}" 
                            SelectedItem="{Binding SelectedMajor}" 
                            ItemDisplayBinding="{Binding name}"
                            TextColor="White"
                            HorizontalOptions="Center"
                            BackgroundColor="Black"
                            WidthRequest="220"
                            FontSize="12"
                            FontAttributes="Bold"
                            />
                </StackLayout>
            </FlexLayout>

            <FlexLayout
                JustifyContent="SpaceEvenly"
                AlignItems="Center"
                HorizontalOptions="Fill"
                Margin="0, 10, 0, 0"
                >
                <StackLayout Orientation="Horizontal" Spacing="10" VerticalOptions="Center">
                    <Label Text="Academic Year: " TextColor="White" FontSize="12" FontAttributes="Bold" VerticalTextAlignment="Center"/>
                    <Label Text="{Binding Student.academicYear.label}" TextColor="White" FontSize="18" VerticalTextAlignment="Center" FontAttributes="Bold"/>
                </StackLayout>
                <StackLayout Orientation="Horizontal" Spacing="10" VerticalOptions="Center">
                    <Label Text="Change Aacdemic Year: " FontSize="12" FontAttributes="Bold" TextColor="White" VerticalTextAlignment="Center"/>
                    <Picker ItemsSource="{Binding AcademicYears}" 
                            SelectedItem="{Binding SelectedAcademicYear}" 
                            ItemDisplayBinding="{Binding label}"
                            TextColor="White"
                            HorizontalOptions="Center"
                            BackgroundColor="Black"
                            WidthRequest="220"
                            FontSize="12"
                            FontAttributes="Bold"
                            />
                </StackLayout>
            </FlexLayout>


            <Button Text="Save Changes" 
                    Command="{Binding SaveStudentCommand}" 
                    Margin="0,30,0,0"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>